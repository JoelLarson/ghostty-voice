# ghostty-voice configuration.
# Copy to ~/.config/ghostty-voice/config.toml and edit.

[whisper]
binary        = "whisper-server"      # path or name on PATH; config so a rename isn't a rebuild
extra_args    = []                    # passthrough launch flags
host          = "127.0.0.1"
port          = 8910
model_path    = "~/.local/share/ghostty-voice/models/ggml-large-v3.bin"
# PCI address of the GPU to pin (ADR-0001). Find yours with `lspci`.
# In S1 you launch whisper-server yourself; this is used from S2 on.
vulkan_device = "0000:03:00.0"
# Accuracy stack (S4). beam_size 8 buys accuracy on ambiguous audio; temperature
# 0.0 keeps decoding deterministic.
beam_size   = 8
temperature = 0.0
# initial_prompt biasing: the prefix sentence plus the vocab terms (appended
# after " Vocabulary:") seed the decoder toward your jargon's correct spelling.
# Grow `vocab` as you notice misses — it's bounded to Whisper's ~224-token cap,
# and the daemon warns (rather than silently dropping terms) if you overflow it.
prompt_prefix = "Transcript of technical instructions."
vocab = [
  "ydotool", "Ghostty", "whisper.cpp", "faster-whisper", "kubectl", "ripgrep",
  "useEffect", "rebase", "git stash", "Wayland", "systemd", "Vulkan", "Claude Code",
]

[audio]
# PipeWire source name, or "default" for the default input.
device = "default"
# Runaway-recording safety cap (~900 s): on expiry the recorder stops and the
# utterance is enqueued so speech isn't lost.
max_recording_seconds = 900
# Recordings shorter than this are discarded (accidental blips type nothing).
min_duration_seconds = 0.3
# VAD mode (Super+Shift+D): sox auto-stops after this many seconds of trailing
# silence below vad_threshold_pct (% of full scale). Tune to your mic and room.
vad_silence_seconds = 2.0
vad_threshold_pct = 3
# Continuous mode (Super+Ctrl+D): talk continuously and clips are cut at short
# pauses, transcribed in the background, then assembled and delivered when you
# stop for a while. Tune these to your speech rhythm:
#   clip_cut_pause_seconds      - a pause this long cuts the current clip (~0.8-1.5 s)
#   session_end_silence_seconds - a silence this long ends the session and delivers (~10 s)
#   min_clip_seconds            - clips shorter than this fold into the next, so
#                                 stutters don't spray tiny fragments at Whisper (~2-3 s)
clip_cut_pause_seconds = 1.0
session_end_silence_seconds = 10.0
min_clip_seconds = 2.0

[inject]
# ydotool inter-key delay in ms — raise it if characters drop.
key_delay_ms = 12

[feedback]
# Hot-path audio cues. Two sources, no assets to ship:
#   - a freedesktop THEME EVENT (default): a bare id or a "theme:" prefix, played
#     via `canberra-gtk-play -i <id>` (e.g. "message-new-instant", "dialog-information",
#     "bell"). Browse /usr/share/sounds/freedesktop/stereo for ids.
#   - a FILE path (contains a "/" or starts with "~"): played via `paplay <path>`.
#   - empty: disables that cue.
# sound_start fires when recording begins ("now listening"); sound_stop fires
# when recording ends and on empty/silence ("working / done").
sound_start = "message-new-instant"
sound_stop  = "complete"

[cache]
# WAV recordings kept as an accuracy-debugging corpus (count-capped).
wav_keep = 30
# Transcripts kept to back `replay-last` (count-capped, small).
transcript_keep = 5
# Freshness window (seconds): a transcript produced within this long after the
# recording ends is auto-typed; slower than this it's held for `replay-last`.
# Generous backstop (~15 min), not a routine gate — hands-free is the priority.
retry_window_seconds = 900

# Deterministic jargon spell-fixer (S4): case-insensitive, whole-word
# find/replace applied after transcription, before typing. For terms Whisper
# reliably mishears the same way. A jargon fixer — NOT a code-symbol munger.
# Longer (phrase) keys are applied first so they win over their substrings.
# `reload` re-reads this table live (no model reload).
[corrections]
"why do tool" = "ydotool"
"ghosty"      = "Ghostty"
"cube cuttle" = "kubectl"
